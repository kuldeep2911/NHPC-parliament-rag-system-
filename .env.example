# ═══════════════════════════════════════════════════════════════════════════
# NHPC Parliament Q&A — example environment file (DEV / BUILD machine)
# ═══════════════════════════════════════════════════════════════════════════
# Copy to `.env` and fill in what you need. `.env` is gitignored — kabhi bhi asli
# keys commit mat karna. Har value optional hai: na dene par neeche likha default
# lag jaata hai, so jis tarike se chalana hai bas usi block ko bharo.
#
#   cp .env.example .env
#
# Yeh file DEV/BUILD ke liye hai (cloud models se test karne ke liye). Air-gapped
# PRODUCTION server ke liye alag, pehle se wired template use karo:
#   deploy/.env.production.example   (sab kuch localhost, sirf 4 secrets change)

# ─────────────────────────────────────────────────────────────────────────────
# 1. BACKEND SELECTION — parser aur LLM alag-alag chunte hain
# ─────────────────────────────────────────────────────────────────────────────
# Document parsing/OCR/tables:  docling (local, CPU, offline) | nemotron (NVIDIA NIMs)
NHPC_PARSER_BACKEND=docling
# Extraction LLM (questions + answers ko line-span se dhoondta hai, grouping karta hai):
#   gemini        - cloud Gemini 2.5 Flash (build phase; text network chhodta hai)
#   ollama        - local/on-prem model (deployment ka rasta)
#   deterministic - koi LLM nahi, sirf rules (last-resort fallback)
NHPC_LLM_BACKEND=gemini
# Primary extraction path — isko on hi rehne do.
NHPC_LLM_GROUPING=1

# ─────────────────────────────────────────────────────────────────────────────
# 2. LLM CREDENTIALS — jo backend upar chuna, sirf uska block bharo
# ─────────────────────────────────────────────────────────────────────────────
# --- GEMINI (build-phase cloud LLM) ---
# Key: https://aistudio.google.com/apikey  (GOOGLE_API_KEY bhi chalta hai).
GEMINI_API_KEY=your_google_ai_studio_key_here
GEMINI_MODEL=gemini-2.5-flash
# 2.5 Flash ek THINKING model hai; extraction me reasoning nahi chahiye, isliye
# thinking budget 0 — warna poora budget soch-vichaar me laga kar khaali reply de deta hai.
GEMINI_THINKING_BUDGET=0

# --- OLLAMA (local/on-prem LLM — kuch bhi network nahi chhodta; DEPLOYMENT) ---
# Production me Nemotron-Super-49B GPU par chalao aur NHPC_LLM_BACKEND=ollama karo.
NHPC_LLM_MODEL=qwen3:14b
NHPC_OLLAMA_BASE_URL=http://localhost:11434/v1
# Server-side JSON mode for the extraction call — each server spells it differently:
#   ollama  Ollama's own {"format":"json"}                      (local Ollama)
#   openai  {"response_format":{"type":"json_object"}}          (vLLM / NIM / OpenAI)
#   off     send neither; the parser recovers JSON from prose
# vLLM REJECTS Ollama's field, so use "openai" when pointing at a vLLM server.
NHPC_LLM_JSON_MODE=ollama
# Optional bearer token if the remote LLM server requires one (vLLM --api-key).
# NHPC_LLM_API_KEY=
# A 49B model over the network is slower than a local 14B — give it room.
# NHPC_LLM_TIMEOUT_S=300

# ─────────────────────────────────────────────────────────────────────────────
# 3. DATABASE — Postgres + pgvector
# ─────────────────────────────────────────────────────────────────────────────
# Bring it up:  cd deploy/postgres && docker compose up -d
PHASE3_DB_DSN=postgresql://nhpc:your_password_here@localhost:5433/nhpc

# ─────────────────────────────────────────────────────────────────────────────
# 4. EMBEDDINGS — sub-question + answer text ko vector me badalta hai
# ─────────────────────────────────────────────────────────────────────────────
#   nvidia_nim_api    - NVIDIA-hosted NIM (dev; text network chhodta hai)
#   nvidia_selfhosted - on-prem NIM / HF weights (server; kuch nahi chhodta)
EMBED_BACKEND=nvidia_nim_api
# Model fixed hai: dim 2048, L2-normalised (cosine), Devanagari OK, passage/query modes.
EMBED_MODEL=nvidia/llama-nemotron-embed-1b-v2
EMBED_DIM=2048
EMBED_URL=https://integrate.api.nvidia.com/v1/embeddings
NVIDIA_EMBED_API_KEY=nvapi-your_embedding_key_here
# On-prem par (EMBED_BACKEND=nvidia_selfhosted) yeh URL set karo, upar wala key hata do:
# EMBED_SELFHOSTED_URL=http://localhost:8801/v1/embeddings

# ─────────────────────────────────────────────────────────────────────────────
# 5. RERANKER — cross-encoder jo candidates ko dobara score karta hai (precision)
# ─────────────────────────────────────────────────────────────────────────────
RERANK_ENABLED=1
RERANK_BACKEND=nvidia_nim_api
RERANK_MODEL=nvidia/llama-nemotron-rerank-1b-v2
RERANK_URL=https://ai.api.nvidia.com/v1/retrieval/nvidia/llama-nemotron-rerank-1b-v2/reranking
NVIDIA_RERANK_API_KEY=nvapi-your_rerank_key_here
# On-prem par: RERANK_BACKEND=nvidia_selfhosted + yeh URL
# RERANK_SELFHOSTED_URL=http://localhost:8802/v1/ranking

# ─────────────────────────────────────────────────────────────────────────────
# 6. RETRIEVAL TUNING — defaults production-calibrated hain, bina zaroorat mat chhedo
# ─────────────────────────────────────────────────────────────────────────────
# Kitne candidates har retriever se aayenge (dense = semantic, entity = proper-noun).
RETRIEVE_DENSE_TOP_N=50
RETRIEVE_ENTITY_TOP_N=30
# Reranker itne candidates score karta hai (yeh display cap NAHI hai).
RERANK_CANDIDATE_POOL=80
# Sigmoid filter sirf LLM-verify ki cost bound karta hai, relevance gate nahi — isliye low.
SIMILARITY_THRESHOLD=0.02
# Answer embeddings: question ke saath answer text bhi search hoti hai (recall gain).
USE_ANSWER_EMBEDDINGS=1
ANSWER_EMBED_WEIGHT=0.5
# LLM verify: har surviving candidate ko "same question?" check — asli precision yahin hoti.
LLM_VERIFY_ENABLED=1

# ─────────────────────────────────────────────────────────────────────────────
# 7. DRAFT ASSIST — retrieved answers se cited draft banata hai (officer review ke liye)
# ─────────────────────────────────────────────────────────────────────────────
DRAFT_ENABLED=1
# Draft kitne retrieved answers dekhta hai (officer jitne dekhta hai utne).
DRAFT_CONTEXT_K=10
DRAFT_MAX_TOKENS=2400
# Supporting reference documents (financial/progress) draft me pull kiye ja sakte hain.
SUPPORTING_ENABLED=1
SUPPORTING_LLM_ASOF=1

# ─────────────────────────────────────────────────────────────────────────────
# 8. PARSING OPTIONS (docling backend ke liye)
# ─────────────────────────────────────────────────────────────────────────────
NHPC_USE_DOCLING=1
NHPC_USE_OCR=1
# IBM TableFormer (docling ke saath aata hai): accurate | fast
NHPC_TABLEFORMER_MODE=accurate

# --- NVIDIA CV NIMs (sirf jab NHPC_PARSER_BACKEND=nemotron) ---
# cloud = NVIDIA-hosted (build); onprem = self-hosted NIMs (production, kuch nahi chhodta)
NVIDIA_MODE=cloud
# Cloud keys (nvapi-xxxx). Ek shared NVIDIA_API_KEY bhi chal jaata hai.
# NVIDIA_OCR_API_KEY=nvapi-...
# NVIDIA_PAGE_ELEMENTS_API_KEY=nvapi-...
# NVIDIA_TABLE_STRUCTURE_API_KEY=nvapi-...
# On-prem NIM endpoints (NVIDIA_MODE=onprem):
# NVIDIA_OCR_URL=http://localhost:8010/v1/infer
# NVIDIA_PAGE_ELEMENTS_URL=http://localhost:8011/v1/infer
# NVIDIA_TABLE_STRUCTURE_URL=http://localhost:8012/v1/infer

# ─────────────────────────────────────────────────────────────────────────────
# 9. AUTH + API
# ─────────────────────────────────────────────────────────────────────────────
# Auth OFF rehne par API sabko allow karta (sirf local dev me theek). Production me on.
AUTH_ENABLED=false
# on karne par: session-signing secret (>= 32 chars) — python -c "import secrets;print(secrets.token_urlsafe(48))"
# AUTH_SECRET_KEY=
# AUTH_ADMIN_EMAIL=admin@nhpc.in
# AUTH_ADMIN_PASSWORD ke saath admin seedha us password se login (varna one-time password print hota).
# AUTH_ADMIN_PASSWORD=
AUTH_PASSWORD_MIN_LENGTH=8
# API loopback par bind hoti hai; reverse proxy TLS terminate karke identity set karta hai.
PHASE4_API_HOST=127.0.0.1
PHASE4_API_PORT=8099

# ─────────────────────────────────────────────────────────────────────────────
# 10. WATCHER — naye folders/files aane par apne aap ingest
# ─────────────────────────────────────────────────────────────────────────────
# `nhpc serve` ke andar hi watcher chalu ho jaata hai (alag process nahi).
WATCHER_WITH_SERVE=true
# Raw source tree jise watcher dekhta hai (READ-ONLY — isme kabhi likhta nahi).
NHPC_SOURCE_ROOT=Original Data

# ─────────────────────────────────────────────────────────────────────────────
# 11. OBSERVABILITY
# ─────────────────────────────────────────────────────────────────────────────
# Har run structured trace likhta hai (raw model output, model, backend, timing).
NHPC_TRACE=1
# Langfuse: browsable trace UI. OFF rehne par SDK import bhi nahi hota (zero cost).
# Sirf self-hosted Langfuse use karo — traces me document content hota hai.
LANGFUSE_ENABLED=0
LANGFUSE_HOST=http://localhost:3000
# LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_SECRET_KEY=sk-lf-...
