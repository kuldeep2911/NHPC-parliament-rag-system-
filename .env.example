# NHPC Parliament RAG — example environment file.
#
# Copy to `.env` and fill in the values you need. `.env` is gitignored; NEVER
# commit real keys. Every variable below is optional — the pipeline falls back to
# the defaults shown, so start with the block that matches how you want to run it.
#
#   cp .env.example .env

# ─────────────────────────────────────────────────────────────────────────────
# BACKEND SELECTION — parser and LLM are chosen independently
# ─────────────────────────────────────────────────────────────────────────────
# Document parsing / OCR / tables:  nemotron (NVIDIA NIMs) | docling (local, CPU)
NHPC_PARSER_BACKEND=docling
# Q&A extraction LLM:
#   gemini        - cloud Gemini 2.5 Flash via Google AI Studio (build phase)
#   ollama        - local/on-prem model, e.g. Qwen3 14B (deployment)
#   groq          - cloud llama-3.3-70b (superseded: 30 rpm free tier throttles runs)
#   deterministic - no LLM at all (rules only; last-resort fallback)
NHPC_LLM_BACKEND=gemini
# The LLM locates questions AND answers by line span, and decides the grouping.
# Leave this on: it is the primary extraction path.
NHPC_LLM_GROUPING=1
# Optional second-opinion check that flags LLM/deterministic disagreement
NHPC_LLM_CROSSCHECK=0

# ─────────────────────────────────────────────────────────────────────────────
# GEMINI (build-phase cloud LLM — document text leaves the network)
# ─────────────────────────────────────────────────────────────────────────────
# Key from https://aistudio.google.com/apikey  (GOOGLE_API_KEY also accepted).
# Uses Google's OpenAI-compatible endpoint, so no extra SDK is required.
GEMINI_API_KEY=your_google_ai_studio_key_here
GEMINI_MODEL=gemini-2.5-flash
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
# Client-side pacing so a burst never 429s and drops a file to the rule-based path
GEMINI_RPM=60
# 2.5 Flash is a THINKING model. Span extraction is extraction, not reasoning, so
# thinking is disabled (0). It otherwise can spend the whole budget reasoning and
# return an empty message.
GEMINI_THINKING_BUDGET=0
GEMINI_MAX_TOKENS=8192

# ─────────────────────────────────────────────────────────────────────────────
# GROQ (alternative cloud LLM — kept working, no longer the default)
# ─────────────────────────────────────────────────────────────────────────────
# Get a key at https://console.groq.com — it looks like: gsk_xxxxxxxx
GROQ_API_KEY=gsk_your_groq_key_here
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_BASE_URL=https://api.groq.com/openai/v1
# Client-side rate limit so we never hit Groq's 429 and every file reaches the LLM
GROQ_RPM=30

# ─────────────────────────────────────────────────────────────────────────────
# OLLAMA (local/on-prem LLM — no data leaves the machine; DEPLOYMENT path)
# ─────────────────────────────────────────────────────────────────────────────
# At NHPC, run Qwen3 14B on the local GPU and set NHPC_LLM_BACKEND=ollama.
#   ollama pull qwen3:14b
# Qwen3 emits <think>...</think> reasoning; the JSON extractor strips it.
NHPC_LLM_MODEL=qwen3:14b
NHPC_OLLAMA_BASE_URL=http://localhost:11434/v1

# ─────────────────────────────────────────────────────────────────────────────
# NVIDIA NeMo Retriever (OCR / page-elements / table-structure)
# ─────────────────────────────────────────────────────────────────────────────
# cloud  = NVIDIA-hosted endpoints (build phase; data leaves the network)
# onprem = self-hosted NIM microservices (production; nothing leaves the network)
NVIDIA_MODE=cloud

# Cloud: one key per model from https://build.nvidia.com (keys look like nvapi-xxxx).
# A single shared NVIDIA_API_KEY also works if you have one key for all three.
NVIDIA_OCR_API_KEY=nvapi-your_ocr_key_here
NVIDIA_PAGE_ELEMENTS_API_KEY=nvapi-your_page_elements_key_here
NVIDIA_TABLE_STRUCTURE_API_KEY=nvapi-your_table_structure_key_here
# NVIDIA_API_KEY=nvapi-shared_key_for_all_three

# Cloud endpoint URLs (defaults shown; override if your model page differs)
# NVIDIA_CLOUD_OCR_URL=https://ai.api.nvidia.com/v1/cv/nvidia/nemoretriever-ocr
# NVIDIA_CLOUD_PAGE_ELEMENTS_URL=https://ai.api.nvidia.com/v1/cv/nvidia/nemoretriever-page-elements-v2
# NVIDIA_CLOUD_TABLE_STRUCTURE_URL=https://ai.api.nvidia.com/v1/cv/nvidia/nemotron-table-structure-v1

# On-prem NIM endpoints (used when NVIDIA_MODE=onprem). Optional bearer token.
# NVIDIA_OCR_URL=http://localhost:8010/v1/infer
# NVIDIA_PAGE_ELEMENTS_URL=http://localhost:8011/v1/infer
# NVIDIA_TABLE_STRUCTURE_URL=http://localhost:8012/v1/infer
# NVIDIA_TOKEN=optional_bearer_token_if_your_nim_requires_one

# ─────────────────────────────────────────────────────────────────────────────
# PARSING OPTIONS
# ─────────────────────────────────────────────────────────────────────────────
NHPC_USE_DOCLING=1
NHPC_USE_OCR=1
# IBM TableFormer (bundled with Docling): accurate | fast
NHPC_TABLEFORMER_MODE=accurate
NHPC_TABLEFORMER_CELL_MATCHING=1
# Path to soffice/libreoffice for legacy .doc conversion (auto-discovered if unset)
# NHPC_LIBREOFFICE=C:\Program Files\LibreOffice\program\soffice.exe

# ─────────────────────────────────────────────────────────────────────────────
# TRACE / OBSERVABILITY
# ─────────────────────────────────────────────────────────────────────────────
# Every run writes structured trace rows (raw model output, model, backend, timing).
# With a DSN they go to Postgres (tables `runs`, `run_steps`); otherwise to JSONL
# under organized/_reports/trace/. The trace holds DOCUMENT CONTENT — apply the same
# access controls and retention as the source data.
NHPC_TRACE=1
# NHPC_TRACE_DSN=postgresql://user:password@localhost:5432/nhpc

# ─────────────────────────────────────────────────────────────────────────────
# LANGFUSE (optional developer trace UI on top of the trace layer above; OFF)
# ─────────────────────────────────────────────────────────────────────────────
# A browsable UI mirror of the trace steps above. The Postgres/JSONL layer stays the
# durable system-of-record; Langfuse only adds a viewer. OFF by default: while false
# the SDK is never imported, nothing connects, and there is zero latency -- leave it
# off on machines that don't run a Langfuse server.
#
# Turn ON only on the on-prem server, pointing at a SELF-HOSTED Langfuse (single
# server). Do NOT use Langfuse cloud: traces carry document content. If enabled but
# keys/host are missing, the run logs an error and continues with Langfuse disabled.
#   pip install "langfuse>=2.53,<3"   (optional; only needed when enabled)
LANGFUSE_ENABLED=0
LANGFUSE_HOST=http://localhost:3000
LANGFUSE_PUBLIC_KEY=pk-lf-your_public_key_here
LANGFUSE_SECRET_KEY=sk-lf-your_secret_key_here

# ─────────────────────────────────────────────────────────────────────────────
# PHASE 3 — Postgres + pgvector, embeddings
# ─────────────────────────────────────────────────────────────────────────────
# Database. Bring it up with: cd deploy/postgres && docker compose up -d
PHASE3_DB_DSN=postgresql://nhpc:your_password_here@localhost:5433/nhpc

# Embedding provider:
#   nvidia_nim_api    - NVIDIA-hosted NIM (dev). Text leaves the network.
#   nvidia_selfhosted - on-prem NIM / HF model (server). Nothing leaves the network.
EMBED_BACKEND=nvidia_nim_api
# NOTE: the originally-specced nvidia/llama-3.2-nv-embedqa-1b-v2 reached END OF LIFE
# on 2026-05-18 and now returns HTTP 410. This is its live successor. Measured:
# dim 2048, L2-normalised output (=> cosine), Devanagari OK, passage/query modes.
EMBED_MODEL=nvidia/llama-nemotron-embed-1b-v2
EMBED_DIM=2048
EMBED_URL=https://integrate.api.nvidia.com/v1/embeddings
NVIDIA_EMBED_API_KEY=nvapi-your_embedding_key_here
EMBED_BATCH_SIZE=32
# 'passage' when indexing sub-questions; Phase-4 search uses 'query'.
EMBED_INPUT_TYPE=passage

# On-prem (EMBED_BACKEND=nvidia_selfhosted): a self-hosted NIM speaking the same API
# EMBED_SELFHOSTED_URL=http://localhost:8000/v1/embeddings
# EMBED_SELFHOSTED_MODEL_PATH=/opt/models/llama-nemotron-embed-1b-v2

# hnsw (approximate, default) | none (exact scan — viable at this corpus size)
PHASE3_VECTOR_INDEX=hnsw

# ─────────────────────────────────────────────────────────────────────────────
# PHASE 4 — hybrid retrieval, rerank, optional generation
# ─────────────────────────────────────────────────────────────────────────────
# RERANKER. NOTE: the spec's nvidia/nv-rerankqa-mistral-4b-v3 does NOT exist (404) and
# llama-3.2-nv-rerankqa-1b-v2 is END OF LIFE (410). Rerankers are not listed by
# GET /v1/models — they live on ai.api.nvidia.com under a per-model path.
RERANK_ENABLED=1
RERANK_BACKEND=nvidia_nim_api
RERANK_MODEL=nvidia/llama-nemotron-rerank-1b-v2
RERANK_URL=https://ai.api.nvidia.com/v1/retrieval/nvidia/llama-nemotron-rerank-1b-v2/reranking
NVIDIA_RERANK_API_KEY=nvapi-your_rerank_key_here
# On-prem (RERANK_BACKEND=nvidia_selfhosted): same request/response shape
# RERANK_SELFHOSTED_URL=http://localhost:8001/v1/ranking

# Candidates per retriever, and the final top-K after reranking
RETRIEVE_DENSE_TOP_N=30
RETRIEVE_KEYWORD_TOP_N=30
RETRIEVE_ENTITY_TOP_N=30
RETRIEVE_FINAL_TOP_K=5

# Reciprocal Rank Fusion: score = sum(weight_r / (RRF_K + rank_r))
RRF_K=60
RRF_W_DENSE=1.0
RRF_W_KEYWORD=0.7
RRF_W_ENTITY=0.5

# WIDEN retry (capped at once). RRF scores are NOT 0-1 — measured on this corpus:
# strong queries score 0.027..0.085 with a #1-#2 gap >= 0.0017; vague ones gap at 0.0004.
# The GAP is the discriminating signal, so DELTA does the work and TAU is a low floor.
# Re-measure with: python -m phase4.scripts.measure_rrf
WIDEN_ENABLED=1
WIDEN_TAU=0.0150
WIDEN_DELTA=0.0015
# What widening DOES: top-N x factor, entity relaxes to boost-only, metadata filters drop
WIDEN_TOP_N_FACTOR=3

# OPTIONAL answer drafting. OFF by default. Uses the Phase-2 LLM provider
# (NHPC_LLM_BACKEND); drafts strictly from retrieved answers with inline citations and is
# labelled "DRAFT FOR OFFICER REVIEW". A failure here never costs the officer results.
GENERATION_ENABLED=0
GENERATION_MAX_TOKENS=1200

# API. Port 8080 is often reserved on Windows — 8099 works.
PHASE4_API_HOST=127.0.0.1
PHASE4_API_PORT=8099
# RBAC. Identity comes from X-User-Id / X-User-Role, set by the authenticating proxy in
# front of this service. Without such a proxy those headers are self-asserted — keep the
# bind address on 127.0.0.1.
PHASE4_ROLES_QUERY=officer,admin
PHASE4_ROLES_FILE=officer,admin
