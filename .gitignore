# ── Secrets — NEVER commit API keys or tokens ───────────────────────────
.env
.env.*
# ...but DO track the placeholder templates (contain no real secrets)
!.env.example
!*.example
!*.env.example
*.key
*.pem

# ── Data — do NOT push document content or the raw source tree ──────────
# Raw Phase-1 source (parliamentary PDFs/DOCX) and the organized/ output
# (parsed.json + copied files) contain document content and are large (GBs).
Original Data/
PARLIAMENT*/
organized/
# raw-data archives (session dumps) — large and hold document content, never commit
*.rar
*.zip
*.7z
# trace output (JSONL run steps) holds document content — never commit
_reports/
**/_reports/

# ── Python ──────────────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
.venv/
venv/
.env/

# ── Editor / OS ─────────────────────────────────────────────────────────
.vscode/
.idea/
.DS_Store
Thumbs.db

# ── Claude local settings (may contain machine paths) ───────────────────
.claude/

# Uploaded reference documents — runtime data, like organized/ and Original Data/
supporting_documents/
