# ═══════════════════════════════════════════════════════════════════════════
# NHPC Q&A — PRODUCTION .env  (fully on-prem / air-gapped)
# ═══════════════════════════════════════════════════════════════════════════
# Copy this to the PROJECT ROOT as `.env` and change ONLY the four values marked
# «CHANGE ME». Everything else is already wired to the local services in
# deploy/postgres/ and deploy/models/. `.env` is gitignored — never commit it.
#
#   cp deploy/.env.production.example .env
#
# The three golden rules of this file:
#   1. Nothing points at the internet. Every URL below is localhost.
#   2. All model backends are the *_selfhosted / ollama variants.
#   3. The four «CHANGE ME» secrets are the only edits required.

# ─────────────────────────────────────────────────────────────────────────────
# 1. SECRETS — the only values you must change
# ─────────────────────────────────────────────────────────────────────────────
# (a) Postgres password. MUST match POSTGRES_PASSWORD in deploy/postgres/.env
DB_PASSWORD=«CHANGE ME - strong db password»
PHASE3_DB_DSN=postgresql://nhpc:«CHANGE ME - same db password»@localhost:5433/nhpc

# (b) Session-signing secret. Any random string >= 32 chars.
#     Generate one:  python -c "import secrets; print(secrets.token_urlsafe(48))"
AUTH_SECRET_KEY=«CHANGE ME - random 48+ char string»

# (c) The first admin. The bootstrap creates this account so you can log in.
#     - Set AUTH_ADMIN_PASSWORD to a chosen password and you log in with it directly.
#     - Leave AUTH_ADMIN_PASSWORD blank and a one-time password is printed to the logs
#       (journalctl -u nhpc-bootstrap), which you then change on first login.
AUTH_ADMIN_EMAIL=«CHANGE ME - admin@nhpc.in»
AUTH_ADMIN_PASSWORD=«CHANGE ME - admin login password (>= 8 chars), or leave blank»

# ─────────────────────────────────────────────────────────────────────────────
# 2. LOCAL MODELS — all on-prem, nothing leaves the network
#    (these URLs match deploy/models/docker-compose.yml port mappings)
# ─────────────────────────────────────────────────────────────────────────────
# --- embeddings: self-hosted NIM ---
EMBED_BACKEND=nvidia_selfhosted
EMBED_MODEL=nvidia/llama-nemotron-embed-1b-v2
EMBED_DIM=2048
EMBED_INPUT_TYPE=passage
EMBED_BATCH_SIZE=32
EMBED_SELFHOSTED_URL=http://localhost:8801/v1/embeddings

# --- reranker: self-hosted NIM ---
RERANK_ENABLED=1
RERANK_BACKEND=nvidia_selfhosted
RERANK_MODEL=nvidia/llama-nemotron-rerank-1b-v2
RERANK_SELFHOSTED_URL=http://localhost:8802/v1/ranking

# --- LLM: Nemotron Super 49B (draft, verify, entity discovery) -------------
# Production model is NVIDIA Llama-3.3-Nemotron-Super-49B-v1. The client is OpenAI-compatible,
# so it works with a local Ollama OR a remote vLLM/NIM — only the URL and JSON mode change.
NHPC_LLM_BACKEND=ollama
NHPC_LLM_GROUPING=1
# A 49B model (especially over the network) is slow on first token; give it room.
NHPC_LLM_TIMEOUT_S=300

# OPTION A — Ollama on THIS server (model tag must match what you imported):
NHPC_LLM_MODEL=nemotron-super-49b
NHPC_OLLAMA_BASE_URL=http://localhost:11434/v1
NHPC_LLM_JSON_MODE=ollama

# OPTION B — vLLM on a SEPARATE server (comment out Option A and use these).
# NHPC_LLM_MODEL must equal vLLM's --served-model-name. vLLM rejects Ollama's "format"
# field, so JSON mode MUST be "openai" (it sends response_format instead).
# NHPC_LLM_MODEL=nemotron-super-49b
# NHPC_OLLAMA_BASE_URL=http://<LLM_SERVER_IP>:8000/v1
# NHPC_LLM_JSON_MODE=openai
# NHPC_LLM_API_KEY=                 # only if vLLM was started with --api-key

# --- document parsing: fully local (Docling, CPU — the default; needs no GPU NIMs) ---
# Docling runs entirely offline on CPU and handles the corpus. It needs NONE of the NVIDIA
# CV NIMs. Keep this for a straightforward air-gapped deploy.
NHPC_PARSER_BACKEND=docling
NHPC_USE_DOCLING=1
NHPC_USE_OCR=1
NHPC_TABLEFORMER_MODE=accurate
#
# OPTIONAL higher-accuracy parsing via on-prem NVIDIA CV NIMs (OCR + page layout + table
# structure). Only if you need sharper extraction on scanned/complex tables. To enable:
#   1. cd deploy/models && docker compose --profile cv up -d   (starts the 3 CV NIMs)
#   2. uncomment the four lines below.
# These run locally on the GPU; nothing leaves the network.
# NHPC_PARSER_BACKEND=nemotron
# NVIDIA_MODE=onprem
# NVIDIA_OCR_URL=http://localhost:8010/v1/infer
# NVIDIA_PAGE_ELEMENTS_URL=http://localhost:8011/v1/infer
# NVIDIA_TABLE_STRUCTURE_URL=http://localhost:8012/v1/infer

# ─────────────────────────────────────────────────────────────────────────────
# 3. RETRIEVAL / DRAFT tuning  (production-calibrated — leave as-is unless tuning)
# ─────────────────────────────────────────────────────────────────────────────
SIMILARITY_THRESHOLD=0.02
RETRIEVE_DENSE_TOP_N=50
RETRIEVE_ENTITY_TOP_N=30
RERANK_CANDIDATE_POOL=80
SAFETY_MAX_RESULTS=50
LLM_VERIFY_ENABLED=1
USE_ANSWER_EMBEDDINGS=1
ANSWER_EMBED_WEIGHT=0.5
DRAFT_ENABLED=1
DRAFT_CONTEXT_K=10
DRAFT_MAX_TOKENS=2400
SUPPORTING_ENABLED=1
SUPPORTING_LLM_ASOF=1
# Offline LLM entity discovery when a file is uploaded (uses the local Ollama; safe on-prem)
ENTITIES_LLM_ON_UPLOAD=1

# ─────────────────────────────────────────────────────────────────────────────
# 4. AUTH + API
# ─────────────────────────────────────────────────────────────────────────────
AUTH_ENABLED=true
AUTH_ROLES=admin,officer
AUTH_PASSWORD_MIN_LENGTH=8
# The API binds to loopback and sits behind a reverse proxy that terminates TLS.
# Cookies are marked Secure ONLY when reached over https; on plain loopback keep this
# false. If officers hit the proxy over https (recommended), set it true.
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAMESITE=lax
PHASE4_API_HOST=127.0.0.1
PHASE4_API_PORT=8099

# ─────────────────────────────────────────────────────────────────────────────
# 5. WATCHER — auto-ingest new question folders + reference docs
# ─────────────────────────────────────────────────────────────────────────────
# The watcher runs automatically inside `nhpc serve` (WATCHER_WITH_SERVE=true).
WATCHER_WITH_SERVE=true
# The read-only source tree the watcher observes for new files.
NHPC_SOURCE_ROOT=/opt/nhpc/data/Original Data
WATCH_SETTLE_SECONDS=10
WATCH_POLL_SECONDS=5

# ─────────────────────────────────────────────────────────────────────────────
# 6. LOGGING / TRACE
# ─────────────────────────────────────────────────────────────────────────────
NHPC_LOG_JSON=1
NHPC_TRACE=1

# --- Langfuse (self-hosted observability UI — all on-prem) ---
# The Langfuse server runs via deploy/langfuse/docker-compose.yml. After it boots, create a
# project in its UI and paste the generated keys below. Needs the `langfuse` pip package
# (already in requirements.txt). Set to 0 to disable (the SDK is then never imported).
LANGFUSE_ENABLED=1
LANGFUSE_HOST=http://localhost:3000
LANGFUSE_PUBLIC_KEY=«CHANGE ME - pk-lf-... from the Langfuse UI»
LANGFUSE_SECRET_KEY=«CHANGE ME - sk-lf-... from the Langfuse UI»
