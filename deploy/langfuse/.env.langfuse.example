# Secrets for the Langfuse SERVER containers (docker-compose.yml in this folder).
#
# These are the server's OWN internal secrets (database + storage passwords, plus
# Langfuse's at-rest encryption keys). They are NOT the pipeline's API keys -- those
# (pk-lf-.../sk-lf-...) you generate IN the Langfuse UI after it boots, and put in the
# project-root .env under LANGFUSE_PUBLIC_KEY / LANGFUSE_SECRET_KEY.
#
#   cp .env.langfuse.example .env
#   # then replace every value below with a real secret
#   docker compose up -d
#
# Generate strong values (each unique):
#   openssl rand -base64 24     # for the passwords
#   openssl rand -hex 32        # for LANGFUSE_ENCRYPTION_KEY (must be 64 hex chars)
#   openssl rand -base64 32     # for SALT and NEXTAUTH_SECRET
#
# This file (the real .env, not this template) MUST NOT be committed. It is covered
# by the repo .gitignore (.env / .env.*).

POSTGRES_PASSWORD=change_me_postgres
CLICKHOUSE_PASSWORD=change_me_clickhouse
REDIS_PASSWORD=change_me_redis
MINIO_PASSWORD=change_me_minio

# Langfuse app secrets
SALT=change_me_salt_base64
LANGFUSE_ENCRYPTION_KEY=change_me_64_hex_chars_openssl_rand_hex_32
NEXTAUTH_SECRET=change_me_nextauth_base64
