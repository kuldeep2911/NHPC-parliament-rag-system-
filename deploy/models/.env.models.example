# deploy/models/.env  — local model-serving config. Copy to `.env` (same folder).
#
# On the AIR-GAPPED server you generally leave NGC_API_KEY EMPTY: the images are already
# loaded from saved tarballs and do not phone home. NGC_API_KEY is only needed on a machine
# WITH internet that pulls the NIM images/weights for the first time.

# NGC key — ONLY for pulling on an internet-connected machine. Empty on the air-gapped server.
NGC_API_KEY=

# Pin the exact image digests you saved, so the server can never pull a different build.
# (Replace :latest with the @sha256:... digest of the image you actually copied over.)
EMBED_IMAGE=nvcr.io/nim/nvidia/llama-nemotron-embed-1b-v2:latest
RERANK_IMAGE=nvcr.io/nim/nvidia/llama-nemotron-rerank-1b-v2:latest
OLLAMA_IMAGE=ollama/ollama:0.5.7

# Host ports (must match the *_SELFHOSTED_URL / OLLAMA_BASE_URL in the project .env)
EMBED_PORT=8801
RERANK_PORT=8802
OLLAMA_PORT=11434

# Folder holding the Ollama model blob + Modelfile to import once (see README_DEPLOY.md)
OLLAMA_IMPORT_DIR=./ollama-import

# ── OPTIONAL: NVIDIA CV NIMs for high-accuracy parsing ───────────────────────
# Only used if you run `docker compose --profile cv up -d` AND set
# NHPC_PARSER_BACKEND=nemotron + NVIDIA_MODE=onprem in the project .env. Docling (the
# default) needs none of these. Ports must match NVIDIA_*_URL in the project .env.
OCR_IMAGE=nvcr.io/nim/nvidia/nemoretriever-ocr-v1:latest
PAGE_ELEMENTS_IMAGE=nvcr.io/nim/nvidia/nemoretriever-page-elements-v2:latest
TABLE_STRUCTURE_IMAGE=nvcr.io/nim/nvidia/nemoretriever-table-structure-v1:latest
OCR_PORT=8010
PAGE_ELEMENTS_PORT=8011
TABLE_STRUCTURE_PORT=8012
