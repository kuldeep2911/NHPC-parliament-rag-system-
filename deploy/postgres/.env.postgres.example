# Secrets for the Phase-3 Postgres container (docker-compose.yml in this folder).
#
#   cp .env.postgres.example .env
#   # set a real password (openssl rand -base64 24)
#   docker compose up -d
#
# The real .env here is gitignored. Keep the password in sync with PHASE3_DB_DSN in
# the PROJECT-ROOT .env, which is what the loader/embedder read.

POSTGRES_USER=nhpc
POSTGRES_DB=nhpc
POSTGRES_PASSWORD=change_me_use_openssl_rand_base64_24
POSTGRES_PORT=5433
